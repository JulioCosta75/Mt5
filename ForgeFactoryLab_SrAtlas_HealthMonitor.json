      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [800, 320]
    },
    {
      "parameters": {
        "jsCode": "// ────────────────────────────────────────────────────────────\n// Sr. Atlas — Forge Factory Lab | Structured Report Builder\n// Reads each health node by name so a single failed service\n// never breaks the supervisor. Truth before automation.\n// ────────────────────────────────────────────────────────────\n\nconst check = (nodeName) => {\n  try {\n    const item = $(nodeName).first();\n    if (!item || !item.json) return false;\n    const j = item.json;\n    // continueRegularOutput puts an 'error' key when the request failed\n    if (j.error !== undefined && j.error !== null) return false;\n    const code = j.statusCode;\n    if (typeof code === 'number') return code >= 200 && code < 400;\n    // No status code but a body came back → service is reachable\n    return Object.keys(j).length > 0;\n  } catch (e) {\n    return false;\n  }\n};\n\nconst backend_ok   = check('Atlas Backend Health');\nconst bridge_ok    = check('MT5 Bridge Health');\nconst dashboard_ok = check('Atlas Dashboard Health');\n\nconst all_ok = backend_ok && bridge_ok && dashboard_ok;\n\nconst down = [];\nif (!backend_ok)   down.push('Atlas Backend (8001)');\nif (!bridge_ok)    down.push('MT5 Bridge (8002)');\nif (!dashboard_ok) down.push('Atlas Dashboard (8001)');\n\nconst message = all_ok\n  ? 'All Forge Factory Lab core services are online and healthy.'\n  : `Degraded system — not responding: ${down.join(', ')}.`;\n\nconst report = {\n  supervisor: 'Sr. Atlas',\n  ecosystem: 'Forge Factory Lab',\n  status: all_ok ? 'OK' : 'ALERT',\n  backend_ok,\n  bridge_ok,\n  dashboard_ok,\n  timestamp: new Date().toISOString(),\n  message,\n};\n\n// all_ok is kept as a helper flag for the IF node below\nreturn [{ json: { ...report, all_ok } }];\n"
      },
      "id": "code-report-0009",
      "name": "Sr. Atlas Report Builder",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 320]
    },
